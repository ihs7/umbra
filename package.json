{
  "name": "@ihs7/umbra",
  "version": "0.6.0",
  "description": "The Swiss-army knife of CLI generation",
  "repository": {
    "type": "git",
    "url": "https://github.com/ihs7/umbra"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "umbra": "dist/generate.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck && oxlint --deny-warnings src/",
    "format": "oxfmt --write src/ bin/",
    "format:check": "oxfmt --check src/ bin/",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "typescript": "^5",
    "zod": "^4",
    "yaml": "^2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.5.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
